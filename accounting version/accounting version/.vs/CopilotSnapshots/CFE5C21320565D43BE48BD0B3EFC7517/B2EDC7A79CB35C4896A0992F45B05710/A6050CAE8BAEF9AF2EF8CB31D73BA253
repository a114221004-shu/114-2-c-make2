using System;
using System.Collections.Generic;
using System.ComponentModel;
using System.Data;
using System.Drawing;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using System.Windows.Forms;
using static System.Windows.Forms.VisualStyles.VisualStyleElement.Tab;

namespace accounting_version
{
    public partial class Form1 : Form
    {
        // 自訂方法所用的資料結構
        private List<int> moneyList = new List<int>();

        public Form1()
        {
            InitializeComponent();

            // 訂閱自訂事件，當新增支出時會呼叫 OnExpenseAdded
            this.ExpenseAdded += OnExpenseAdded;
        }
        private void BtnOk_Click(object sender, EventArgs e)
        {
            // ❗ 沒輸入項目 → 擋住
            if (TxtItem.Text.Trim() == "")
            {
                MessageBox.Show("請輸入項目");
                return;
            }

            // ❗ 沒輸入金額
            if (label1.Text.Trim() == "")
            {
                MessageBox.Show("請輸入金額");
                return;
            }

            int money;
            if (!int.TryParse(label1.Text, out money))
            {
                MessageBox.Show("金額格式不正確，請輸入整數");
                return;
            }

            string item = TxtItem.Text;
            GetMoneyList().Add(money);

            // 顯示在 listBox
            listBox1.Items.Add(item + " - $" + money);

            // 清空輸入框
            label1.Text = "";
            TxtItem.Text = "";

            // ⭐ 觸發自訂事件
            ExpenseAdded?.Invoke(this, EventArgs.Empty);
        }

        private List<int> GetMoneyList()
        {
            return moneyList;
        }

        private void BtnCalculate_Click(object sender, EventArgs e)
        {
            MessageBox.Show("總金額：" + GetTotal());
        }
        private void BtnClear_Click(object sender, EventArgs e)
        {
            moneyList.Clear();
            listBox1.Items.Clear();

            // 更新顯示
            ExpenseAdded?.Invoke(this, EventArgs.Empty);
        }
        private int GetTotal()
        {
            int sum = 0;
            foreach (int m in moneyList)
            {
                sum += m;
            }
            return sum;
        }

        // 自訂事件
        public event EventHandler ExpenseAdded;

        // 自訂事件的處理方法 (自訂方法)
        private void OnExpenseAdded(object sender, EventArgs e)
        {
            // 👉 這裡你可以選擇要不要即時顯示
            // 例如更新 Label（如果你有）
            // 確保 LblTotal 在設計器中存在
            if (this.InvokeRequired)
            {
                this.Invoke(new Action(() => LblTotal.Text = "目前總額：" + GetTotal()));
            }
            else
            {
                LblTotal.Text = "目前總額：" + GetTotal();
            }
        }
        private void Form1_Load(object sender, EventArgs e)
        {

        }
    }
}
